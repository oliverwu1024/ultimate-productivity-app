# Android / Kotlin
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
android/captures/
android/*.iml

# Android release signing (NEVER commit — losing the keystore = cannot update on Play Store)
android/ultiq-release.jks
android/keystore.properties

# Firebase config (FCM, §9.8). google-services.json holds project + app IDs
# and a client API key — repo is public so we don't commit it; each dev
# downloads their own from the Firebase Console. The variant-specific copy
# at src/debug/ (added for side-by-side dogfood installs via
# applicationIdSuffix=".debug") is also gitignored.
android/app/google-services.json
android/app/src/debug/google-services.json

# Firebase Admin service-account credentials (server-side push send). NEVER
# commit — full FCM send capability for the project. Prod copy lives in
# AWS Secrets Manager; local copy lives in the gitignored secrets/ folder.
# NOTE: the Firebase Console downloads the file as <project-id>-firebase-adminsdk-*.json
# (e.g. ultiq-e559d-firebase-adminsdk-*.json). The two prefix patterns below do
# NOT match that (the project-id prefix breaks them), so the leading-* pattern is
# the one that actually catches a Console download anywhere in the tree.
**/firebase-admin*.json
**/ultiq-firebase-adminsdk*.json
**/*firebase-adminsdk*.json

# Local secrets / credentials. Whole folder ignored so ANYTHING inside is
# uncommittable regardless of filename — belt-and-suspenders for the key above.
/secrets/

# Built APKs deployed via S3 sync (not via git — too large)
web-landing/public/*.apk

# Rust
backend/target/
web-dashboard/target/
web-dashboard/dist/
web-dashboard/node_modules/

# Environment
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Docker
docker-compose.override.yml
ultiq-roadmap.md

# Local agent / AI-assistant guidance — kept locally, never published
AGENTS.md
CLAUDE.md

# Phase 13.5 — Play Store store-listing copy. Local-only ops artifact (manual
# paste into Play Console); no repo coupling. Whole folder ignored, incl. README.
/play-store-listing/

# All other markdown is local-only. Only README.md (anywhere in the tree)
# is published. Anything else (release checklists, design notes, scratch
# docs) lives on disk for the developer's reference.
*.md
!README.md
