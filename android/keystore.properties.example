# Template for android/keystore.properties (gitignored).
# Copy to android/keystore.properties and fill in real values.
# Both files live in android/ — Gradle's `rootProject.file(...)` resolves there.
#
# storeFile  : path to the .jks keystore, relative to android/
# storePassword: password used at `keytool -genkey -keystore` time
# keyAlias   : the alias passed via `-alias` (e.g. ultiq)
# keyPassword: alias password (often same as storePassword for personal projects)

storeFile=ultiq-release.jks
storePassword=
keyAlias=ultiq
keyPassword=
