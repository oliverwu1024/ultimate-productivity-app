<?xml version="1.0" encoding="utf-8"?>
<!-- One row in the Checklist widget's scrollable ListView. Tap = tick (complete).
     The root carries a fill-in intent (item id) that merges into the list's
     pending-intent template — see ChecklistWidgetProvider.toggleTemplate. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="5dp"
    android:paddingBottom="5dp">

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_widget_checkbox"
        android:importantForAccessibility="no" />

    <TextView
        android:id="@+id/row_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/widget_text"
        android:textSize="14sp" />
</LinearLayout>
