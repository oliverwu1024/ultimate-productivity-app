<?xml version="1.0" encoding="utf-8"?>
<!-- Interactive RemoteViews Calendar widget: scrollable today's events, tap a row
     (checkbox on the left) to mark it done. Mirrors the Checklist widget
     (RemoteViewsService collection + partiallyUpdateAppWidget header + row-tap
     template). Events stay until ticked — no time-based auto-hide. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calendar_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_card_bg">

    <!-- Tap target to open the Calendar tab. Taller + chevron so it reads as tappable
         (the scrollable list below owns its own row/scroll touches). -->
    <LinearLayout
        android:id="@+id/calendar_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textColor="@color/widget_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/cal_left"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="@color/widget_subtext"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/cal_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_subtext"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="›"
            android:textColor="@color/widget_subtext"
            android:textSize="19sp"
            android:importantForAccessibility="no" />
    </LinearLayout>

    <!-- ListView + its empty view share the same area; the collection adapter toggles
         between them via RemoteViews.setEmptyView. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ListView
            android:id="@+id/cal_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@null"
            android:dividerHeight="0dp" />

        <TextView
            android:id="@+id/cal_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:visibility="gone"
            android:textColor="@color/widget_subtext"
            android:textSize="13sp" />
    </FrameLayout>
</LinearLayout>
