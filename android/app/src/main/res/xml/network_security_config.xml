<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Cleartext only allowed to local dev hosts in debug builds. The release
         build's API_BASE_URL points at https://api.ultiqapp.com so these hosts
         are unreachable from a production install anyway. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">192.168.1.119</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
