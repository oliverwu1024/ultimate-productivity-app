<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome notification small-icon. Android renders smallIcon via the
  alpha channel only (opaque -> white, transparent -> transparent), so
  passing R.mipmap.ic_launcher here used to render the launcher's full
  colored background as a solid "white circle" in the status bar.

  Design: simplified version of the mascot's closed book. The 1dp
  transparent gap between body and spine reads as a separator at status-
  bar scale; below ~18dp the gap collapses and the silhouette reads as a
  filled "book" rectangle, which is still clearly an icon rather than a
  disc.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M5,3 L14,3 L14,21 L5,21 A1,1 0 0 1 4,20 L4,4 A1,1 0 0 1 5,3 Z M15,3 L19,3 A1,1 0 0 1 20,4 L20,20 A1,1 0 0 1 19,21 L15,21 L15,3 Z" />
</vector>
