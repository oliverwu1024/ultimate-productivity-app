<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome adaptive-icon layer used by Android 13+'s "Themed icons"
  feature: when the user opts in, the launcher recolors this single-tone
  glyph to match their wallpaper-derived theme instead of showing the
  full-color launcher. Without this layer the launcher falls back to the
  regular ic_launcher and the icon stays untinted.

  Same closed-book silhouette as ic_notification, drawn in the 108dp
  adaptive-icon viewport. Padding kept generous so the launcher's safe
  zone clip doesn't cut into the book.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,32 L62,32 L62,80 L38,80 A4,4 0 0 1 34,76 L34,36 A4,4 0 0 1 38,32 Z M66,32 L74,32 A4,4 0 0 1 78,36 L78,76 A4,4 0 0 1 74,80 L66,80 L66,32 Z" />
</vector>
